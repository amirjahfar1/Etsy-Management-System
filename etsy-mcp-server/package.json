{
  "name": "etsy-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Etsy API integration",
  "type": "module",
  "bin": {
    "etsy-mcp-server": "./build/index.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "dev": "node --loader ts-node/esm src/index.ts",
    "oauth": "node oauth-setup.js"
  },
  "keywords": [
    "mcp",
    "etsy",
    "api",
    "model-context-protocol"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "axios": "^1.7.2",
    "form-data": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
